# ======================================================
# CashCue App Dockerfile
# ======================================================

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------------
# Install Apache + PHP
# ------------------------------------------------------
RUN apt-get update && \
    apt-get install -y \
        apache2 \
        php8.3 \
        php8.3-cli \
        php8.3-mysql \
        libapache2-mod-php8.3 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------
# Apache configuration
# ------------------------------------------------------
RUN a2enmod rewrite && \
    echo "ServerName localhost" >> /etc/apache2/apache2.conf

# ------------------------------------------------------
# Working directory
# ------------------------------------------------------
WORKDIR /var/www/html

# No COPY — frontend mounted by docker-compose:
# ./web:/var/www/html/cashcue

EXPOSE 80

CMD ["/usr/sbin/apache2ctl", "-D", "FOREGROUND"]